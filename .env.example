# Copy this file to .env and adjust values. .env is gitignored.

# Postgres (shared instance, two databases: users_db, messages_db)
POSTGRES_USER=chatapp
POSTGRES_PASSWORD=chatapp
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# RabbitMQ
RABBITMQ_USER=chatapp
RABBITMQ_PASSWORD=chatapp
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Shared secret for internal service-to-service calls (e.g. Auth Service -> User Service)
INTERNAL_API_KEY=change-me-internal-dev-key

# How long a user is considered online without a heartbeat refresh from Gateway Service
PRESENCE_TTL_SECONDS=90
